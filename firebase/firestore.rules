rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ====================================
    // Admin UIDs — allow-list for admin dashboard reads
    // Seed manually via the Firebase Console: one doc per admin UID,
    // empty body. Read-only from the client.
    // ====================================
    match /adminUids/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // NO write — managed out-of-band
    }

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/adminUids/$(request.auth.uid));
    }

    // ====================================
    // Users — strict owner-only access
    // ====================================
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ====================================
    // Service Requests — owner CRUD + admin read
    // ====================================
    match /serviceRequests/{requestId} {
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid)
                  || isAdmin();
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if (request.auth != null
                        && resource.data.userId == request.auth.uid)
                    || isAdmin();
      // NO delete — requests are permanent records

      // Chat messages — only request owner
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }

      // Service events — admin + request owner can read; nothing else.
      // Writes happen from the worker via service account, which bypasses
      // rules entirely, or from the owner for client-originated events.
      match /events/{eventId} {
        allow read: if (request.auth != null
                       && get(/databases/$(database)/documents/serviceRequests/$(requestId)).data.userId == request.auth.uid)
                    || isAdmin();
        allow create: if request.auth != null
                       && get(/databases/$(database)/documents/serviceRequests/$(requestId)).data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ====================================
    // Bids — read by anyone authed (for now)
    // TODO: restrict to request owner when we add proper indexes
    // ====================================
    match /bids/{bidId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // NO update, NO delete — bids are immutable
    }

    // ====================================
    // Providers (Google Places cache) — read-only from client
    // ====================================
    match /providers/{providerId} {
      allow read: if request.auth != null;
      // NO write from client — only worker (service account)
    }

    // ====================================
    // Provider aggregates — admin dashboard support
    // Worker maintains stats + jobs subcollection via service account.
    // Authed users can read so the customer app can show provider
    // summaries on bid cards.
    // ====================================
    match /providers_agg/{phone} {
      allow read: if request.auth != null;
      allow write: if false;

      match /jobs/{requestId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ====================================
    // Admin daily-rollup stats — admin-only read, worker writes.
    // ====================================
    match /adminStats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ====================================
    // Reviews — write once, read by anyone authed
    // ====================================
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;
      // NO update, NO delete — reviews are permanent
    }

    // ====================================
    // Waitlist — public-ish (authed create only)
    // ====================================
    match /waitlist/{docId} {
      allow create: if request.auth != null;
      // NO read from client
    }

    // ====================================
    // Feedback — authed create + admin read
    // ====================================
    match /feedback/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.freeText.size() <= 2000;
      allow read: if request.auth != null;
      // NO update, NO delete
    }

    // ====================================
    // Session logs — write only (analytics)
    // ====================================
    match /session_logs/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      // NO update, NO delete
    }

    // ====================================
    // Admin alerts — worker creates, admin reads/updates
    // ====================================
    match /admin_alerts/{alertId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      // NO create from client — only worker
      // NO delete
    }

    // ====================================
    // Provider signups — public form (no auth for create)
    // ====================================
    match /provider_signups/{signupId} {
      allow create: if true
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.phone.size() <= 20;
      allow read: if request.auth != null;
      // NO update, NO delete from client
    }

    // ====================================
    // Deny everything else
    // ====================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
