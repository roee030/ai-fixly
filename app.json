{
  "expo": {
    "name": "Fixly",
    "slug": "ai-fixly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fixly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "primaryColor": "#6366F1",
    "description": "Fixly — האובר של תיקוני הבית. צלם, ה-AI מוצא בעלי מקצוע, הצעות מחיר תוך דקות.",
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.aifixly.app",
      "buildNumber": "1",
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleLocalizations": ["he", "en", "ar", "ru"],
        "CFBundleDevelopmentRegion": "he",
        "NSCameraUsageDescription": "האפליקציה צריכה גישה למצלמה כדי לצלם את התקלה ולשלוח אותה לבעלי מקצוע.",
        "NSPhotoLibraryUsageDescription": "האפליקציה צריכה גישה לתמונות כדי לבחור צילום של התקלה מהגלריה.",
        "NSPhotoLibraryAddUsageDescription": "האפליקציה שומרת תמונות שצולמו דרכה אל הגלריה שלך.",
        "NSMicrophoneUsageDescription": "האפליקציה צריכה גישה למיקרופון כדי שתוכל להקליט תיאור קולי של התקלה.",
        "NSLocationWhenInUseUsageDescription": "האפליקציה צריכה את המיקום שלך כדי למצוא בעלי מקצוע באזור.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "package": "com.aifixly.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#0F0F1A",
          "dark": {
            "backgroundColor": "#0F0F1A"
          }
        }
      ],
      "@sentry/react-native",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/crashlytics",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "האפליקציה צריכה גישה לתמונות כדי לבחור צילום של התקלה מהגלריה.",
          "cameraPermission": "האפליקציה צריכה גישה למצלמה כדי לצלם את התקלה."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "האפליקציה צריכה גישה למצלמה כדי לצלם את התקלה."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "האפליקציה צריכה את המיקום שלך כדי למצוא בעלי מקצוע באזור."
        }
      ],
      "@react-native-firebase/messaging",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1266d585-4fe1-46ad-b352-005104c2b6a0"
      }
    },
    "owner": "roeeangel",
    "updates": {
      "url": "https://u.expo.dev/1266d585-4fe1-46ad-b352-005104c2b6a0"
    }
  }
}
