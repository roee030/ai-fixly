# Firebase: download config files from Firebase Console
# Place google-services.json in project root (Android)
# Place GoogleService-Info.plist in project root (iOS)

# Sentry
EXPO_PUBLIC_SENTRY_DSN=

# Gemini AI (Slice 2)
GEMINI_API_KEY=

# WhatsApp Business API (Slice 3)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Supabase Storage
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Twilio WhatsApp Sandbox (only used in dev/local; production uses worker secrets)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Cloudflare Worker URL (the broker between the app and external services)
# After deploying workers/broker, set this to the worker URL
EXPO_PUBLIC_BROKER_URL=https://ai-fixly-broker.your-subdomain.workers.dev
